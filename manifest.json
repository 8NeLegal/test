{
  "manifest_version": 3,
  "name": "GIIS DMDK",
  "description": "Автозаполнение логина, пароля и датчика случайных чисел",
  "version": "3.0.0",
  "author": "Maka",
  "icons": {
        "16":"icons/16.png",
        "32":"icons/32.png",
        "48":"icons/48.png",
        "128":"icons/128.png"
  },
  "action": {
    "default_title": "Автозаполнение логина, пароля и датчика случайных чисел",
    "default_icon": "icons/32.png"
  },
  "content_scripts": [
    {
        "js": [
          "js/content.js"
        ],
        "matches": [
          "http://localhost:15243/login",
          "http://localhost:15243/connect"
        ]
    }
  ],
	"permissions": [
    "scripting", 
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "js/background.js"
  }
}